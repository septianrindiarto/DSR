# ─── Database ────────────────────────────────────────────────────────────
# Postgres connection string used by Drizzle.
DATABASE_URL=postgres://user:pass@localhost:5432/dsr

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000

# ─── Better Auth ─────────────────────────────────────────────────────────
# Generate a fresh secret with:  openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-32-byte-hex-secret

# Base URL Better Auth uses to build callback links inside emails. Should
# match how the API itself is reachable (not the frontend domain).
BETTER_AUTH_URL=http://localhost:5000

# Frontend origin allowed to send cookies / call the API.
CORS_ORIGIN=http://localhost:5173

# Public-facing URL of the React app. Used to construct the verification
# link the user clicks in their email (e.g. `${APP_URL}/verify-email?token=...`).
# Override per environment (dev = localhost, prod = your domain).
APP_URL=http://localhost:5173

# ─── Gmail SMTP (transactional email) ────────────────────────────────────
# Sender Gmail address — full email (works with personal @gmail.com or
# Google Workspace addresses like admin@yourdomain.com).
GMAIL_USER=admin@dsrappai.com
GMAIL_FROM_NAME=DSR Solution

# ─── Pick ONE auth mode below ────────────────────────────────────────────
#
# Mode A — OAuth2 (REQUIRED for Google Workspace accounts; App Passwords
# are not available in most Workspace orgs as of 2024).
#
# Setup (one-time, ~30 min):
#   1. console.cloud.google.com → New project (or pick existing)
#   2. APIs & Services → Enabled APIs & services → "+ Enable APIs" → Gmail API
#   3. APIs & Services → OAuth consent screen → External → fill in app name,
#      support email, save. Add scope: https://mail.google.com/
#      Add your Workspace email as a Test user.
#   4. APIs & Services → Credentials → Create credentials → OAuth client ID
#      Application type: Web application
#      Authorized redirect URI: https://developers.google.com/oauthplayground
#      Copy the Client ID + Client Secret.
#   5. Open https://developers.google.com/oauthplayground
#      Top-right gear icon → tick "Use your own OAuth credentials" →
#      paste Client ID + Client Secret.
#      In "Step 1" → manually type scope: https://mail.google.com/
#      Click Authorize APIs → sign in as admin@dsrappai.com → Allow.
#      In "Step 2" → click "Exchange authorization code for tokens".
#      Copy the Refresh token.
#   6. Paste below:
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# Mode B — App Password (personal @gmail.com only; ignore for Workspace).
# Setup: enable 2-Step Verification at myaccount.google.com/security, then
# create an App Password at myaccount.google.com/apppasswords.
GMAIL_APP_PASSWORD=

# The code uses OAuth2 if all three OAUTH_ vars are set; otherwise it falls
# back to GMAIL_APP_PASSWORD. Leave the unused mode blank.

# ─── Misc ────────────────────────────────────────────────────────────────
DEBUG=false

# Admin WhatsApp number for booking notifications (optional).
ADMIN_WHATSAPP=

# Telegram admin alerts (free, recommended).
# Get a bot token from @BotFather in Telegram, then /start your bot and grab
# your chat id from https://api.telegram.org/bot{TOKEN}/getUpdates.
# Comma-separate multiple chat ids if more than one admin should be alerted.
# Leave blank to disable Telegram notifications entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
